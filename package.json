{
    "name": "imagic-validator",
    "version": "3.1.0",
    "description": "Validate objects against typed schemas with chainable rules and structured error reporting",
    "type": "module",
    "exports": {
        ".": "./src/index.js",
        "./package.json": "./package.json"
    },
    "files": ["src", "README.md", "LICENSE"],
    "sideEffects": false,
    "scripts": {
        "test": "node --test ./tests/**/*.test.js",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix"
    },
    "engines": {
        "node": ">=24"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iMagicKey/validator.git"
    },
    "keywords": [
        "validator",
        "validate",
        "validation",
        "datamatch"
    ],
    "author": "iMagicKey",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/iMagicKey/validator/issues"
    },
    "homepage": "https://github.com/iMagicKey/validator#readme",
    "devDependencies": {
        "@eslint/js": "latest",
        "chai": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-plugin-import": "latest",
        "eslint-plugin-n": "latest",
        "eslint-plugin-prettier": "latest",
        "eslint-plugin-promise": "latest",
        "globals": "latest",
        "prettier": "latest"
    }
}
